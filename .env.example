# Email Configuration for Gmail
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password
FROM_EMAIL=your_gmail@gmail.com
RECIPIENT_EMAIL=your_recipient@email.com

# Anthropic Claude API Configuration (for prioritization agent)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

#APIs
OPENSTATES_API_KEY=key-here
GOOGLE_CIVIC_API_KEY=key-here

# Ollama (local LLM for privacy analysis -- all processing stays on your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# Safety: reject non-localhost Ollama URLs to prevent browsing data from leaving your machine.
# Set to False ONLY if you intentionally run Ollama on a trusted remote host.
PRIVACY_REQUIRE_LOCAL_OLLAMA=True
